# ============================
# SupportForge UI — Environment Configuration
# ============================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ============================
# API Connection
# ============================
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/api/v1/ws/chat

# ============================
# Application
# ============================
VITE_APP_NAME=SupportForge
VITE_APP_ENV=development               # development | staging | production

# ============================
# Model Configuration (read-only display in Admin Panel)
# ============================
VITE_CHAT_MODEL=gemma3:4b                # Chat model displayed in Admin Panel (available: gemma3:4b, qwen3:4b)
VITE_EMBEDDING_MODEL=nomic-embed-text   # Embedding model displayed in Admin Panel
